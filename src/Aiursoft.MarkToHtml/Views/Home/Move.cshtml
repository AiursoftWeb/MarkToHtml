@model Aiursoft.MarkToHtml.Models.HomeViewModels.MoveViewModel

<h1 class="h3 mb-3">@Localizer["Move Document"]</h1>

<div class="row mb-3">
    <div class="col">
        <div class="alert alert-primary alert-outline" role="alert">
            <div class="alert-icon">
                <i class="align-middle" data-lucide="file-text"></i>
            </div>
            <div class="alert-message">
                <strong>@Localizer["Moving:"]</strong>
                @(string.IsNullOrWhiteSpace(Model.DocumentTitle) ? "(no title)" : Model.DocumentTitle)
            </div>
        </div>
    </div>
</div>

@* Breadcrumb navigation *@
<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item">
            <a asp-action="Move" asp-route-id="@Model.DocumentId">@Localizer["Root"]</a>
        </li>
        @if (Model.BrowseFolder != null)
        {
            @* Build breadcrumb by walking up parents — we only have one level of context,
               so show the current folder name as the last item *@
            <li class="breadcrumb-item active" aria-current="page">@Model.BrowseFolder.Name</li>
        }
    </ol>
</nav>

<div class="row">
    <div class="col-12 col-xl-6">
        @* "Move Here" card for the current folder *@
        <div class="card mb-3 border-primary">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <i class="align-middle me-2" data-lucide="folder"></i>
                    @if (Model.BrowseFolder != null)
                    {
                        <strong>@Model.BrowseFolder.Name</strong>
                        <span class="text-muted ms-2">@Localizer["Move to this folder"]</span>
                    }
                    else
                    {
                        <strong>@Localizer["Root"]</strong>
                        <span class="text-muted ms-2">@Localizer["Move to root (no folder)"]</span>
                    }
                </div>
                <form asp-action="Move" asp-route-id="@Model.DocumentId" method="post" class="m-0">
                    <input type="hidden" name="targetFolderId" value="@(Model.BrowseFolderId?.ToString() ?? "")" />
                    <button type="submit" class="btn btn-primary">
                        <i class="align-middle me-2" data-lucide="folder-input"></i> @Localizer["Move Here"]
                    </button>
                </form>
            </div>
        </div>

        @* Subfolders — click to browse deeper *@
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Subfolders"]</h5>
                <h6 class="card-subtitle text-muted">@Localizer["Click a folder to browse deeper, or use 'Move Here' to select current location."]</h6>
            </div>
            @if (!Model.SubFolders.Any())
            {
                <div class="card-body">
                    <p class="text-muted mb-0">@Localizer["No subfolders here."]</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var folder in Model.SubFolders)
                    {
                        <a asp-action="Move" asp-route-id="@Model.DocumentId" asp-route-browseFolderId="@folder.Id"
                           class="list-group-item list-group-item-action d-flex align-items-center">
                            <i class="align-middle me-3" data-lucide="folder"></i>
                            <span>@folder.Name</span>
                            <i class="align-middle ms-auto" data-lucide="chevron-right"></i>
                        </a>
                    }
                </div>
            }
            <div class="card-footer text-end">
                <a asp-action="History" asp-route-folderId="@Model.BrowseFolderId" class="btn btn-light">@Localizer["Cancel"]</a>
            </div>
        </div>
    </div>
</div>
