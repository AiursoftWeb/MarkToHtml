@model Aiursoft.MarkToHtml.Models.TagViewModels.DeleteTagViewModel

<h1 class="h3 mb-3">@Localizer["Delete Tag"]</h1>

<div class="row">
    <div class="col-12 col-xl-6">
        <div class="card border-danger">
            <div class="card-header bg-danger-subtle">
                <h5 class="card-title mb-0 text-danger">
                    <i class="align-middle me-2" data-lucide="alert-triangle"></i>
                    @Localizer["Delete \"{0}\"?", Model.Name]
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-danger alert-outline mb-3" role="alert">
                    <div class="alert-icon">
                        <i class="align-middle" data-lucide="alert-octagon"></i>
                    </div>
                    <div class="alert-message">
                        <strong>@Localizer["This action is irreversible."]</strong>
                        @Localizer["This tag will be permanently deleted from all documents."]
                    </div>
                </div>

                <h6>@Localizer["Tag information:"]</h6>
                <ul class="list-group mb-3">
                    <li class="list-group-item d-flex align-items-center gap-2">
                        <i class="align-middle text-muted" data-lucide="tag"></i>
                        <span>@Localizer["Name: {0}", Model.Name]</span>
                    </li>
                    <li class="list-group-item d-flex align-items-center gap-2">
                        <i class="align-middle text-muted" data-lucide="file-text"></i>
                        <span>@Localizer["{0} document(s) will be affected", Model.DocumentCount]</span>
                    </li>
                    @if (Model.DocumentCount > 0)
                    {
                        <li class="list-group-item d-flex align-items-center gap-2 bg-warning-subtle">
                            <i class="align-middle" data-lucide="alert-circle"></i>
                            <span>
                                <strong>@Localizer["Warning:"]</strong>
                                @Localizer["The tag will be removed from {0} document(s).", Model.DocumentCount]
                            </span>
                        </li>
                    }
                </ul>
            </div>
            <div class="card-footer text-end">
                <a asp-action="Index" class="btn btn-light me-2">
                    @Localizer["Cancel"]
                </a>
                <form asp-action="DeleteTag" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger">
                        <i class="align-middle me-2" data-lucide="trash-2"></i>
                        @Localizer["Delete Permanently"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>