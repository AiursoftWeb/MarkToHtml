@model Aiursoft.MarkToHtml.Models.TagViewModels.IndexTagViewModel

<h1 class="h3 mb-3">
    <i class="align-middle me-2" data-lucide="tags"></i>
    @Localizer["Tags"]
</h1>

<div class="row mt-3">
    <div class="col-12">
        <div class="card">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="card-title mb-0">
                    @Localizer["All Tags"]
                </h5>
                <div>
                    <a asp-action="CreateTag" class="btn btn-primary btn-sm">
                        <i class="align-middle me-2" data-lucide="plus"></i>
                        @Localizer["New Tag"]
                    </a>
                </div>
            </div>
            <div class="card-body">
                @if (Model.Tags.Count == 0)
                {
                    <div class="alert alert-info mb-0">
                        <i class="align-middle me-2" data-lucide="info"></i>
                        @Localizer["No tags yet. Create one to label your documents."]
                    </div>
                }
                else
                {
                    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                        @foreach (var tag in Model.Tags)
                        {
                            <div class="col">
                                <div class="card border-light h-100">
                                    <div class="card-body d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="badge @(string.IsNullOrEmpty(tag.Color) ? "bg-secondary" : $"bg-" + tag.Color)">
                                                <i class="align-middle me-1" data-lucide="tag"></i>
                                                @tag.Name
                                            </span>
                                            <span class="text-muted small">
                                                @Localizer["{0} docs", tag.DocumentCount]
                                            </span>
                                        </div>
                                        <div class="btn-group">
                                            <a asp-action="EditTag" asp-route-id="@tag.Id" class="btn btn-light btn-sm">
                                                <i class="align-middle" data-lucide="pencil"></i>
                                            </a>
                                            <a asp-action="DeleteTag" asp-route-id="@tag.Id" class="btn btn-danger btn-sm">
                                                <i class="align-middle" data-lucide="trash-2"></i>
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>
</div>