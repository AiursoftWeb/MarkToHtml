@model Aiursoft.MarkToHtml.Models.TagViewModels.EditTagViewModel

<h1 class="h3 mb-3">@Localizer["Edit Tag"]</h1>

<div class="row">
    <div class="col-12 col-xl-6">
        <form asp-action="EditTag" method="post">
            <input type="hidden" asp-for="Id" />
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Tag Details"]</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">@Localizer["Tag Name"]</label>
                        <input asp-for="Name" class="form-control" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Color" class="form-label">@Localizer["Color"]</label>
                        <select asp-for="Color" class="form-select">
                            <option value="">@Localizer["Default (Gray)"]</option>
                            <option value="primary">@Localizer["Blue"]</option>
                            <option value="success">@Localizer["Green"]</option>
                            <option value="danger">@Localizer["Red"]</option>
                            <option value="warning">@Localizer["Yellow"]</option>
                            <option value="info">@Localizer["Cyan"]</option>
                        </select>
                        <span asp-validation-for="Color" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="align-middle me-2" data-lucide="check-circle"></i> @Localizer["Save Changes"]
                    </button>
                    <a asp-action="Index" class="btn btn-light">@Localizer["Cancel"]</a>
                </div>
            </div>
        </form>
    </div>
</div>