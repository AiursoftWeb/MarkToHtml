@model Aiursoft.MarkToHtml.Models.CategoryViewModels.CreateCategoryViewModel

<h1 class="h3 mb-3">@Localizer["Create New Category"]</h1>

<div class="row">
    <div class="col-12 col-xl-6">
        <form asp-action="CreateCategory" method="post">
            <input type="hidden" asp-for="ParentCategoryId" />
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Category Details"]</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="Name" class="form-label">@Localizer["Category Name"]</label>
                        <input asp-for="Name" class="form-control" placeholder="@Localizer["e.g. Technology, Travel, Personal"]" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Description" class="form-label">@Localizer["Description"] <span class="text-muted">(@Localizer["Optional"])</span></label>
                        <input asp-for="Description" class="form-control" placeholder="@Localizer["A brief description of this category"]" />
                        <span asp-validation-for="Description" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="align-middle me-2" data-lucide="check-circle"></i> @Localizer["Create Category"]
                    </button>
                    <a asp-action="Index" asp-route-categoryId="@Model.ParentCategoryId" class="btn btn-light">@Localizer["Cancel"]</a>
                </div>
            </div>
        </form>
    </div>
</div>