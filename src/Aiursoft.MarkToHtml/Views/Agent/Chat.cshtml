@inject IViewLocalizer Localizer

<div class="agent-chat-widget" id="agent-chat-widget" style="display:none">
    <div class="agent-chat-header">
        <div>
            <h6>@Localizer["AI Assistant"]</h6>
            <span class="agent-status" id="agent-status-text">@Localizer["Ready"]</span>
        </div>
        <div>
            <button class="btn btn-outline-secondary btn-sm" id="agent-new-chat-btn" title="@Localizer["Start a new conversation"]" type="button" onclick="AgentChat.resetConversation()">@Localizer["New"]</button>
        </div>
    </div>
    <div class="agent-chat-messages" id="agent-messages">
        <div class="chat-message assistant">
            @Localizer["Hi! I'm your editing assistant. Paste your client's feedback or describe the changes you want, and I'll propose edits."]
        </div>
    </div>
    <div class="agent-thinking-bar" id="agent-thinking-bar" style="display:none">
        <div class="agent-thinking-dots">
            <span></span><span></span><span></span>
        </div>
        <span class="agent-thinking-text">@Localizer["Thinking..."]</span>
    </div>
    <div class="agent-chat-input">
        <textarea id="agent-input" rows="1" placeholder="@Localizer["Paste client feedback or describe changes you want..."]" onkeydown="AgentChat.handleInputKeydown(event)"></textarea>
        <button class="btn btn-primary btn-sm" id="agent-send-btn" type="button" onclick="AgentChat.sendMessage()">@Localizer["Send"]</button>
    </div>
</div>

<div id="agent-loc-data" style="display:none">
    <span data-key="thinking">@Localizer["Thinking..."]</span>
    <span data-key="thinking-status">@Localizer["Thinking..."]</span>
    <span data-key="waiting-approval">@Localizer["Waiting for approval"]</span>
    <span data-key="ready">@Localizer["Ready"]</span>
    <span data-key="error">@Localizer["Error"]</span>
    <span data-key="error-prefix">@Localizer["Error:"]</span>
    <span data-key="network-error">@Localizer["Network error:"]</span>
    <span data-key="approved-executing">@Localizer["Approved - applying..."]</span>
    <span data-key="rejected">@Localizer["Rejected"]</span>
    <span data-key="proposed-edit">@Localizer["Proposed Edit"]</span>
    <span data-key="replace-with">@Localizer["Replace with"]</span>
    <span data-key="approve">@Localizer["Approve"]</span>
    <span data-key="reject">@Localizer["Reject"]</span>
    <span data-key="edit-applied">@Localizer["Edit applied successfully!"]</span>
    <span data-key="save-first">@Localizer["Please save the document first before using the AI assistant."]</span>
</div>
