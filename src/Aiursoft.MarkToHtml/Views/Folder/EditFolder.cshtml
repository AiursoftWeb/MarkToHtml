@model Aiursoft.MarkToHtml.Models.FolderViewModels.EditFolderViewModel

<h1 class="h3 mb-3">
    @Localizer["Edit Folder"]
    <small class="text-muted">— @Model.Name</small>
</h1>

@* Rename form *@
<div class="row mb-3">
    <div class="col-12 col-xl-6">
        <form asp-action="EditFolder" method="post" id="rename-form">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="BrowseParentFolderId" />
            <div class="card">
                <div class="card-header">
                    <h5 class="card-title mb-0">@Localizer["Folder Name"]</h5>
                </div>
                <div class="card-body">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <div class="mb-0">
                        <input asp-for="Name" class="form-control" placeholder="@Localizer["Folder name"]" />
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                </div>
                <div class="card-footer text-end">
                    <button type="submit" name="action" value="save" class="btn btn-primary">
                        <i class="align-middle me-2" data-lucide="save"></i> @Localizer["Save Changes"]
                    </button>
                    <a asp-action="Index" asp-route-id="@Model.BrowseParentFolderId" class="btn btn-light">@Localizer["Cancel"]</a>
                </div>
            </div>
        </form>
    </div>
</div>

@* Move folder section — tree navigation to select new parent *@
<div class="row">
    <div class="col-12 col-xl-6">
        <nav aria-label="breadcrumb" class="mb-2">
            <ol class="breadcrumb">
                <li class="breadcrumb-item">
                    <a asp-action="EditFolder" asp-route-id="@Model.Id">@Localizer["Root"]</a>
                </li>
                @foreach (var ancestor in Model.Breadcrumb)
                {
                    <li class="breadcrumb-item">
                        <a asp-action="EditFolder" asp-route-id="@Model.Id" asp-route-browseFolderId="@ancestor.Id">@ancestor.Name</a>
                    </li>
                }
                @if (Model.BrowseFolder != null)
                {
                    <li class="breadcrumb-item active" aria-current="page">@Model.BrowseFolder.Name</li>
                }
            </ol>
        </nav>

        <div class="alert alert-primary alert-outline mb-3" role="alert">
            <div class="alert-icon">
                <i class="align-middle" data-lucide="folder-tree"></i>
            </div>
            <div class="alert-message">
                <span>@Localizer["Browse to a new parent folder, then click 'Move Here'. Leave name unchanged to only move."]</span>
            </div>
        </div>

        @* "Move Here" card for current browse location *@
        <div class="card mb-3 border-success">
            <div class="card-body d-flex align-items-center justify-content-between">
                <div>
                    <i class="align-middle me-2" data-lucide="folder"></i>
                    @if (Model.BrowseFolder != null)
                    {
                        <strong>@Model.BrowseFolder.Name</strong>
                        <span class="text-muted ms-2">@Localizer["Move to this folder"]</span>
                    }
                    else
                    {
                        <strong>@Localizer["Root"]</strong>
                        <span class="text-muted ms-2">@Localizer["Move to root"]</span>
                    }
                </div>
                <form asp-action="EditFolder" method="post">
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="Name" value="@Model.Name" />
                    <input type="hidden" name="BrowseParentFolderId" value="@(Model.BrowseParentFolderId?.ToString() ?? "")" />
                    <button type="submit" class="btn btn-success">
                        <i class="align-middle me-2" data-lucide="folder-input"></i> @Localizer["Move Here"]
                    </button>
                </form>
            </div>
        </div>

        @* Subfolders — click to browse deeper *@
        <div class="card">
            <div class="card-header">
                <h5 class="card-title mb-0">@Localizer["Subfolders"]</h5>
                <h6 class="card-subtitle text-muted">@Localizer["Click a folder to browse deeper."]</h6>
            </div>
            @if (!Model.SubFolders.Any())
            {
                <div class="card-body">
                    <p class="text-muted mb-0">@Localizer["No subfolders here."]</p>
                </div>
            }
            else
            {
                <div class="list-group list-group-flush">
                    @foreach (var folder in Model.SubFolders)
                    {
                        <a asp-action="EditFolder" asp-route-id="@Model.Id" asp-route-browseFolderId="@folder.Id"
                           class="list-group-item list-group-item-action d-flex align-items-center">
                            <i class="align-middle me-3" data-lucide="folder"></i>
                            <span>@folder.Name</span>
                            <i class="align-middle ms-auto" data-lucide="chevron-right"></i>
                        </a>
                    }
                </div>
            }
        </div>
    </div>
</div>
