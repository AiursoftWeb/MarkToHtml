@model Aiursoft.MarkToHtml.Models.FolderViewModels.DeleteFolderViewModel

<h1 class="h3 mb-3">@Localizer["Delete Folder"]</h1>

<div class="row">
    <div class="col-12 col-xl-6">
        <div class="card border-danger">
            <div class="card-header bg-danger-subtle">
                <h5 class="card-title mb-0 text-danger">
                    <i class="align-middle me-2" data-lucide="alert-triangle"></i>
                    @Localizer["Delete \"{0}\"?", Model.Name]
                </h5>
            </div>
            <div class="card-body">
                <div class="alert alert-danger alert-outline mb-3" role="alert">
                    <div class="alert-icon">
                        <i class="align-middle" data-lucide="alert-octagon"></i>
                    </div>
                    <div class="alert-message">
                        <strong>@Localizer["This action is irreversible."]</strong>
                        @Localizer["All contents of this folder will be permanently deleted."]
                    </div>
                </div>

                <h6>@Localizer["Contents of this folder:"]</h6>
                <ul class="list-group mb-3">
                    @if (Model.DirectDocumentCount > 0)
                    {
                        <li class="list-group-item d-flex align-items-center gap-2">
                            <i class="align-middle text-muted" data-lucide="file-text"></i>
                            <span>@Localizer["{0} document(s)", Model.DirectDocumentCount]</span>
                        </li>
                    }
                    @if (Model.DirectSubFolderCount > 0)
                    {
                        <li class="list-group-item d-flex align-items-center gap-2">
                            <i class="align-middle text-muted" data-lucide="folder"></i>
                            <span>@Localizer["{0} subfolder(s)", Model.DirectSubFolderCount]</span>
                        </li>
                    }

                    @if (Model.RecursiveDocumentCount > Model.DirectDocumentCount || Model.RecursiveSubFolderCount > Model.DirectSubFolderCount)
                    {
                        <li class="list-group-item d-flex align-items-center gap-2 bg-warning-subtle">
                            <i class="align-middle" data-lucide="folder-tree"></i>
                            <span>
                                <strong>@Localizer["Recursively:"]</strong>
                                @Localizer["{0} document(s) and {1} subfolder(s) in total",
                                    Model.RecursiveDocumentCount, Model.RecursiveSubFolderCount]
                            </span>
                        </li>
                    }

                    @if (Model.DirectDocumentCount == 0 && Model.DirectSubFolderCount == 0)
                    {
                        <li class="list-group-item text-muted">
                            <i class="align-middle me-2" data-lucide="folder-open"></i>
                            @Localizer["This folder is empty."]
                        </li>
                    }
                </ul>
            </div>
            <div class="card-footer text-end">
                <a asp-action="History" asp-controller="Home" asp-route-folderId="@Model.ParentFolderId" class="btn btn-light me-2">
                    @Localizer["Cancel"]
                </a>
                <form asp-action="DeleteFolder" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger">
                        <i class="align-middle me-2" data-lucide="trash-2"></i>
                        @Localizer["Delete Permanently"]
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
